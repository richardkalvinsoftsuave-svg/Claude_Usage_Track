# Database: SQLite by default for zero-friction local dev.
# For Postgres use: postgresql://user:password@db:5432/claude_usage
DATABASE_URL=sqlite:///./claude_usage.db

# Postgres credentials used by docker-compose.yml (ignored for SQLite).
POSTGRES_USER=claude_usage
POSTGRES_PASSWORD=claude_usage
POSTGRES_DB=claude_usage

# Where uploaded screenshots are stored (relative to project root).
UPLOAD_DIR=./uploads

# Extraction strategy:
#   ocr_only             - PaddleOCR + regex on every upload (default, lightest)
#   ocr_plus_manual_vlm  - OCR first; user can click "Re-extract with AI" to call local Ollama
#   docling_only         - Docling (local vision model) on every upload
#   docling_plus_manual_vlm - Docling first; AI re-extract button calls local Ollama
#   vlm_only             - Always call the local VLM (slow, CPU-only)
EXTRACTION_MODE=docling_only

# Local Ollama instance used only for manual "Re-extract with AI".
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:3b

# Max uploaded screenshot size in bytes (10 MB).
MAX_FILE_SIZE=10485760
