# Database: MySQL with PyMySQL driver.
# MySQL must be running with a database named `usage_db`.
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/usage_db

# MySQL credentials (used by docker-compose if applicable).
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DB=usage_db

# Where uploaded screenshots are stored (relative to project root).
UPLOAD_DIR=./uploads

# Extraction strategy:
#   ocr_only             - PaddleOCR + regex on every upload (default, lightest)
#   ocr_plus_manual_vlm  - OCR first; user can click "Re-extract with AI" to call local Ollama
#   vlm_only             - Always call the local VLM (slow, CPU-only)
EXTRACTION_MODE=ocr_only

# Local Ollama instance used only for manual "Re-extract with AI".
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:3b

# Max uploaded screenshot size in bytes (10 MB).
MAX_FILE_SIZE=10485760
